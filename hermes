#!/usr/bin/env bash
set -euo pipefail

project_root="$(cd "$(dirname "$0")" && pwd)"
local_home="$project_root/.agents/hermes"
global_hermes="$HOME/.local/bin/hermes"
global_env="$HOME/.hermes/.env"

if [[ ! -x "$global_hermes" ]]; then
  echo "Global Hermes binary not found at $global_hermes" >&2
  exit 1
fi

mkdir -p "$local_home" "$project_root/.agents/skills"

# Keep local state in this repo, but inherit the current global provider creds.
if [[ -f "$global_env" ]]; then
  while IFS='=' read -r key value; do
    [[ -z "${key:-}" ]] && continue
    [[ "$key" =~ ^# ]] && continue
    case "$key" in
      OPENROUTER_API_KEY|OPENAI_API_KEY|FIRECRAWL_API_KEY|NOUS_API_KEY|FAL_KEY|BROWSERBASE_API_KEY|BROWSERBASE_PROJECT_ID|TAVILY_API_KEY|PARALLEL_API_KEY|LLM_MODEL)
        export "$key=$value"
        ;;
    esac
  done < "$global_env"
fi

export HERMES_HOME="$local_home"
export HERMES_GATEWAY_HOME="$local_home"

exec "$global_hermes" "$@"
